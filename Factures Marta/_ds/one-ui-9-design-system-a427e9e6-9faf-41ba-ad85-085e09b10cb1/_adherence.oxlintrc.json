{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/buttons/**",
              "components/data-display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/media/**",
              "components/navigation/**",
              "ui_kits/calendar/**",
              "ui_kits/lockscreen/**",
              "ui_kits/phone/**",
              "ui_kits/settings/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|color|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|leadingIcon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, leadingIcon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|interactive|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, interactive, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|color|disabled|onClick|ariaLabel|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, color, disabled, onClick, ariaLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|label|type|disabled|leadingIcon|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, label, type, disabled, leadingIcon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LargeTitleHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|count|leading|actions|align|back|onBack|titleColor|topSpace|style|key|ref|className|style|children)$/]",
        "message": "<LargeTitleHeader> doesn't accept that prop. Declared props: title, count, leading, actions, align, back, onBack, titleColor, topSpace, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LargeTitleHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<LargeTitleHeader> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:leading|title|subtitle|trailing|onClick|interactive|subtitleColor|wrapSubtitle|style|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: leading, title, subtitle, trailing, onClick, interactive, subtitleColor, wrapSubtitle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|icon|key|ref|className|style|children)$/]",
        "message": "<NavBarItem> doesn't accept that prop. Declared props: value, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='NowBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|artist|playing|onToggle|onPrev|onNext|leading|style|key|ref|className|style|children)$/]",
        "message": "<NowBar> doesn't accept that prop. Declared props: title, artist, playing, onToggle, onPrev, onNext, leading, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|onChange|disabled|trackHeight|handle|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: value, min, max, onChange, disabled, trackHeight, handle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Snackbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:message|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<Snackbar> doesn't accept that prop. Declared props: message, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|disabled|onChange|ariaLabel|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, disabled, onChange, ariaLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaveScrubber'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|onChange|color|remainingColor|height|amplitude|wavelength|style|key|ref|className|style|children)$/]",
        "message": "<WaveScrubber> doesn't accept that prop. Declared props: value, min, max, onChange, color, remainingColor, height, amplitude, wavelength, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
